<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Match Summary</title>

    <link rel="stylesheet" href="/style.css">
</head>

<body class="old-internet">

    <div class="results-box">

        <p class="results-label">MATCH SUMMARY</p>

        <h1 id="compatibility-score" class="compatibility-score">
            0%
        </h1>

        <p class="compatibility-title">
            Compatibility
        </p>

        <p id="difference-score" class="difference-score">
            Difference Score: 100%
        </p>

<img
    id="profile-photo"
    class="profile-photo"
    src=""
    alt="Profile photo"
>

        <h2 id="profile-name">
            Loading profile...
        </h2>

        <p id="profile-message">
            Preparing your perfect mismatch.
        </p>

        <div class="profile-details">

            <p>
                <strong>Personal introduction:</strong>
            </p>

            <p id="profile-bio"></p>

            <p>
                <strong>Favorite music:</strong>
                <span id="profile-music"></span>
            </p>

            <p>
                <strong>Ideal weekend:</strong>
                <span id="profile-weekend"></span>
            </p>

            <p>
                <strong>Personality:</strong>
                <span id="profile-personality"></span>
            </p>

            <p>
                <strong>Most important value:</strong>
                <span id="profile-value"></span>
            </p>

        </div>

        <button id="another-match-button">
            FIND ANOTHER MATCH
        </button>

        <button onclick="window.location.href='/'">
            RETURN HOME
        </button>

    </div>

    <script src="/results.js"></script>

</body>

</html>